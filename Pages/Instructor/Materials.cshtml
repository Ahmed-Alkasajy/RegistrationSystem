@page
@model student_online_system.Pages.Instructor.MaterialsModel
@{
    ViewData["Title"] = "Course Materials";
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h3 class="mb-3">Course Materials</h3>

        @if (Model.Materials.Count == 0)
        {
            <p class="text-muted">No materials uploaded</p>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>File Name</th>
                        <th>Upload Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Materials)
                    {
                        <tr class="hover-option">
                            <td>@m.FileName</td>
                            <td>@m.UploadDate.ToShortDateString()</td>
                            <td>
                                <a class="btn btn-outline-primary btn-sm"
                                   href="@m.FilePath" target="_blank">
                                    Download
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <hr />

        <h5 class="mt-3">Add Material</h5>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post" enctype="multipart/form-data">
            <input type="hidden" name="CourseId" value="@Model.CourseId" />

            <div class="mb-3">
                <input type="file" name="File" class="form-control" required />
            </div>

            <button class="btn btn-primary btn-sm" type="submit">
                Upload
            </button>
        </form>


        <a href="/Instructor/CourseMaterials" class="btn btn-outline-light mt-3">
            Back
        </a>
    </div>
</div>
