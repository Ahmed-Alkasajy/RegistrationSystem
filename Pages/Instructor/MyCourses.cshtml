@page
@model student_online_system.Pages.Instructor.MyCoursesModel
@{
    ViewData["Title"] = "My Courses";
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h3 class="mb-3">My Courses</h3>

        @if (Model.Courses.Count == 0)
        {
            <p class="text-muted">You are not assigned to any courses</p>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Capacity</th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Courses)
                    {
                        <tr class="hover-option">
                            <td>@c.CourseCode</td>
                            <td>@c.CourseName</td>
                            <td>@c.DepartmentName</td>
                            <td>@c.Capacity</td>
                            <td>
                                <a class="btn btn-outline-light btn-sm"
                                   href="/Instructor/CourseStudents?courseId=@c.CourseId">
                                    Students
                                </a>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
