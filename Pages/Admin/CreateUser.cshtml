@page
@model student_online_system.Pages.Admin.CreateUserModel
@{
    ViewData["Title"] = "Create User";
}

<div class="container" style="max-width:780px;">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h3 class="mb-1">Create User</h3>
            <p class="text-muted">Create student or instructor accounts (Admin only)</p>

            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="alert alert-info">@Model.Message</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post" class="mt-3">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Full Name</label>
                        <input name="FullName" class="form-control form-control-lg" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Role</label>
                        <select name="Role" class="form-select form-select-lg" required>
                            <option class="list-option" value="Student">Student</option>
                            <option class="list-option" value="Instructor">Instructor</option>
                            <option class="list-option" value="Admin">Admin</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input name="EMail" type="email" class="form-control form-control-lg" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input name="Password" type="password" class="form-control form-control-lg" required />
                    </div>

                    <div class="col-12">
                        <button class="btn btn-danger btn-lg" type="submit">Create</button>
                        <a class="btn btn-outline-light btn-lg ms-2" href="/Admin/Dashboard">Back</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
