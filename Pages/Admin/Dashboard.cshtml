@page
@model student_online_system.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row g-3">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="mb-1">Admin Dashboard</h3>
                <p class="text-muted mb-0">Manage users, departments, and courses</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <a class="text-decoration-none" href="/Admin/CreateUser">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5>Create User</h5>
                    <p class="text-muted mb-0">Add Student / Instructor accounts</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a class="text-decoration-none" href="/Admin/Departments">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5>Departments</h5>
                    <p class="text-muted mb-0">Add and view departments</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a class="text-decoration-none" href="/Admin/Courses">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5>Courses</h5>
                    <p class="text-muted mb-0">Create courses and set capacity</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a class="text-decoration-none" href="/Admin/AssignInstructor">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5>Assign Instructors</h5>
                    <p class="text-muted mb-0">Assign Instructors to Courses</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Admin/ResetPassword" class="text-decoration-none">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h5>Reset Password</h5>
                    <p class="text-muted mb-0">
                        Search users by email and reset their passwords
                    </p>
                </div>
            </div>
        </a>
    </div>


</div>
