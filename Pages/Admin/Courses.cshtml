@page
@model student_online_system.Pages.Admin.CoursesModel
@{
    ViewData["Title"] = "Courses";
}

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5>Create Course</h5>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Message))
                {
                    <div class="alert alert-info">@Model.Message</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <select class="form-select form-select-lg" name="DepartmentId" required>
                            @foreach (var d in Model.Departments)
                            {
                                <option class="list-option" value="@d.DepartmentId">@d.DepartmentName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Course Code</label>
                        <input class="form-control form-control-lg" name="CourseCode" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Course Name</label>
                        <input class="form-control form-control-lg" name="CourseName" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Capacity</label>
                        <input class="form-control form-control-lg" type="number" name="Capacity" min="1" required />
                    </div>

                    <button class="btn btn-danger btn-lg w-100" type="submit">Create</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="mb-3">Existing Courses</h5>

                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Capacity</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Courses)
                        {
                            <tr class="hover-option">
                                <td>@c.CourseCode</td>
                                <td>@c.CourseName</td>
                                <td>@c.DepartmentName</td>
                                <td>@c.Capacity</td>
                                <td>
                                    <form method="post">
                                        <input type="hidden" name="DeleteCourseId" value="@c.CourseId" />
                                        <button class="btn btn-danger btn-sm" type="submit">Remove</button>
                                    </form>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.Courses.Count == 0)
                {
                    <p class="text-muted mb-0">No courses yet</p>
                }
            </div>
        </div>
    </div>
</div>
