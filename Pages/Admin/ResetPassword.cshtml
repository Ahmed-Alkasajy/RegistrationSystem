@page
@model student_online_system.Pages.Admin.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="mb-1">Search Users</h4>
                <p class="text-muted mb-3">Search by email or full name</p>

                <form method="post">
                    <input type="hidden" name="Action" value="Search" />

                    <div class="mb-3">
                        <label class="form-label">Search</label>
                        <input class="form-control form-control-lg"
                               name="Search"
                               value="@Model.Search"
                               placeholder="example: @@gmail or tareq"
                               required />
                    </div>

                    <button class="btn btn-danger btn-lg w-100" type="submit">Search</button>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.SearchMessage))
                {
                    <div class="alert alert-info mt-3">@Model.SearchMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
                }
            </div>
        </div>

        @if (Model.Users.Count > 0)
        {
            <div class="card shadow-sm mt-3">
                <div class="card-body p-4">
                    <h5 class="mb-3">Results</h5>

                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model.Users)
                            {
                                <tr class="hover-option">
                                    <td>@u.FullName</td>
                                    <td>@u.EMail</td>
                                    <td>@u.Role</td>
                                    <td>
                                        <form method="post" style="display:inline;">
                                            <input type="hidden" name="Action" value="Select" />
                                            <input type="hidden" name="SelectedUserId" value="@u.UserId" />
                                            <input type="hidden" name="Search" value="@Model.Search" />
                                            <button class="btn btn-outline-light btn-sm" type="submit">Select</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        }
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="mb-1">Reset Password</h4>
                <p class="text-muted mb-3">Admin-only action</p>

                @if (Model.SelectedUserId > 0)
                {
                    <div class="alert alert-secondary">
                        Selected User ID: <strong>@Model.SelectedUserId</strong>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                    {
                        <div class="alert alert-info">@Model.SuccessMessage</div>
                    }

                    <form method="post">
                        <input type="hidden" name="Action" value="Reset" />
                        <input type="hidden" name="SelectedUserId" value="@Model.SelectedUserId" />
                        <input type="hidden" name="Search" value="@Model.Search" />

                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input class="form-control form-control-lg" type="password" name="NewPassword" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Confirm Password</label>
                            <input class="form-control form-control-lg" type="password" name="ConfirmPassword" required />
                        </div>

                        <div class="form-text mb-3">
                            Password must be at least 8 characters, include 1 uppercase letter, and 1 number
                        </div>

                        <button class="btn btn-danger btn-lg w-100" type="submit">
                            Reset Password
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-muted mb-0">Search and select a user first</p>
                }
            </div>
        </div>
    </div>
</div>
